.DS_Store
.venv/
__pycache__/
*.py[cod]

# Rust build artifacts
/target/

# Local SQLite databases may contain device serials and personal ring data.
*.db
*.db-journal
*.sqlite

# Local BLE captures may include serials, MAC-derived identifiers, or auth data.
captures/
*.pcap
*.pcapng
*.btsnoop
*.log

# Reverse-engineering work products are large and may include proprietary app code.
reverse/android/*.xapk
reverse/android/*.apk
reverse/android/*page.html
reverse/android/xapk/
reverse/android/apktool-main/
reverse/android/jadx-main/

# Auth keys generated by `oura pair`.
*.key

# Personal data exports and local working notes (kept off the repo).
*.csv
notes/

# Playwright MCP artifacts
.playwright-mcp/
